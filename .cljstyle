{:files {:ignore #{"target"}},
 :rules
 {:indentation
  {:indents
   {or [[:block 2] [:inner 1]],
    #"^:?import$" [[:block 0]],
    #"^:?require$" [[:block 0]],
    #"^:?use$" [[:block 0]],
    #"^[^ \[]" [[:inner 0]]}},
  :namespaces {:enabled? false},
  :vars {:enabled? false},
  :remove-multiple-non-indenting-spaces? true
  :blank-lines {:max-consecutive 1, :padding-lines 1}}}
