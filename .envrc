use flake /Users/kieran/Documents/github.nosync/kjothen/config/nix/nvim+clj

# Set Java library path for FoundationDB native library
# The flake already sets DYLD_LIBRARY_PATH, so we use that
if [ -n "$DYLD_LIBRARY_PATH" ]; then
  # Extract just the FDB lib path (first entry before colon)
  FDB_LIB_PATH="${DYLD_LIBRARY_PATH%%:*}"
  export JAVA_TOOL_OPTIONS="-Djava.library.path=${FDB_LIB_PATH}"
fi
