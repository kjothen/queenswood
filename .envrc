source_up_if_exists
if has nix; then
  use flake .
else
  echo "nix not found — run scripts/check-setup.sh for install instructions"
fi

echo "Prepping libraries..."
clj -X:deps prep :aliases '[:dev]'

if [[ -z "${MONO_ADMIN_API_KEY:-}" ]]; then
  echo "WARNING: MONO_ADMIN_API_KEY is not set"
else
  export VITE_MONO_ADMIN_API_KEY="$MONO_ADMIN_API_KEY"
fi
