{:system {:vault
          {:client {:api-url [#system :ref [:vault :container-api-url]]}
           :container {:docker-image-name "vault:latest"
                       :exposed-ports [8200]
                       :secret-in-vault ["secret/testing" "top_secret=password1"
                                         "db_password=dbpassword1"]
                       :vault-token "my-root-token"}
           :container-api-port
           {:container [#system :ref [:vault :container]] :exposed-port 8200}
           :container-api-url
           {:port [#system :ref [:vault :container-api-port]] :scheme "http"}}}}
