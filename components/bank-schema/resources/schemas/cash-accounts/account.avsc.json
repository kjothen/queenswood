{
  "type": "record",
  "name": "CashAccount",
  "namespace": "com.repldriven.mono.cash_accounts.cash_account_lifecycle",
  "fields": [
    {"name": "organization_id", "type": "string"},
    {"name": "account_id",  "type": "string"},
    {"name": "party_id", "type": "string"},
    {"name": "name",        "type": "string"},
    {"name": "currency",    "type": "string"},
    {"name": "account_status", 
     "type": {"type": "enum",
              "name": "CashAccountStatus",
              "symbols": ["CASH_ACCOUNT_STATUS_OPENING", 
                          "CASH_ACCOUNT_STATUS_OPENED",
                          "CASH_ACCOUNT_STATUS_CLOSING", 
                          "CASH_ACCOUNT_STATUS_CLOSED"]}},
    {"name": "created_at", "type": {"type": "long", "logicalType": "timestamp-millis"}},
    {"name": "updated_at", "type": {"type": "long", "logicalType": "timestamp-millis"}},
    {"name": "product_id",  "type": "string"},
    {"name": "version_id", "type": "string"},
    {"name": "product_type",
      "type": {"type": "enum",
               "name": "ProductType",
               "symbols": ["PRODUCT_TYPE_INTERNAL",
                           "PRODUCT_TYPE_SETTLEMENT",
                           "PRODUCT_TYPE_CURRENT",
                           "PRODUCT_TYPE_SAVINGS",
                           "PRODUCT_TYPE_TERM_DEPOSIT"]}},
    {"name": "payment_addresses",
     "type": {"type": "array",
              "items": {
                "type": "record",
                "name": "PaymentAddress",
                "fields": [
                  {"name": "scheme", 
                   "type": {"type": "enum",
                            "name": "PaymentAddressScheme",
                            "symbols": ["PAYMENT_ADDRESS_SCHEME_SCAN",
                                        "PAYMENT_ADDRESS_SCHEME_IBAN",
                                        "PAYMENT_ADDRESS_SCHEME_SWIFT",
                                        "PAYMENT_ADDRESS_SCHEME_ACH"]}},
                  {"name": "scan",
                   "type": ["null",
                            {"type": "record",
                             "name": "ScanAddress",
                             "fields": [
                               {"name": "sort_code", "type": "string"},
                               {"name": "account_number", "type": "string"}
                             ]}],
                   "default": null},
                  {"name": "value",
                   "type": ["null", "string"],
                   "default": null}
                ]}},
     "default": []},
    {"name": "account_type",
      "type": ["null",
               {"type": "enum",
                "name": "AccountType",
                "symbols": ["ACCOUNT_TYPE_PERSONAL",
                             "ACCOUNT_TYPE_BUSINESS"]}],
      "default": null}
  ]
}
