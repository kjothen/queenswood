{
  "type": "record",
  "name": "TransactionSettled",
  "namespace": "com.repldriven.mono.schemes.payments",
  "fields": [
    {"name": "scheme_transaction_id", "type": "string"},
    {"name": "end_to_end_id",               "type": "string"},
    {"name": "scheme",               "type": "string"},
    {"name": "debit_credit_code",    "type": {
      "type": "enum",
      "name": "DebitCreditCode",
      "symbols": [
        "DEBIT_CREDIT_CODE_UNKNOWN",
        "DEBIT_CREDIT_CODE_DEBIT",
        "DEBIT_CREDIT_CODE_CREDIT"
      ]
    }},
    {"name": "amount",               "type": "long"},
    {"name": "currency",             "type": "string"},
    {"name": "creditor_bban",        "type": ["null", "string"], "default": null},
    {"name": "debtor_name",          "type": ["null", "string"], "default": null},
    {"name": "reference",            "type": ["null", "string"], "default": null},
    {"name": "timestamp_settled",    "type": {"type": "long", "logicalType": "timestamp-millis"}}
  ]
}
