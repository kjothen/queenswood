{
  "type": "record",
  "name": "Idv",
  "namespace": "com.repldriven.mono.idv",
  "fields": [
    {"name": "organization_id", "type": "string"},
    {"name": "verification_id", "type": "string"},
    {"name": "party_id",        "type": "string"},
    {"name": "status",          "type": {"type": "enum",
                                          "name": "IdvStatus",
                                          "symbols": ["IDV_STATUS_PENDING", "IDV_STATUS_IN_REVIEW",
                                                       "IDV_STATUS_ACCEPTED", "IDV_STATUS_REJECTED",
                                                       "IDV_STATUS_FAILED"]}},
    {"name": "created_at",   "type": {"type": "long", "logicalType": "timestamp-millis"}},
    {"name": "completed_at", "type": ["null", {"type": "long", "logicalType": "timestamp-millis"}], "default": null},
    {"name": "updated_at",   "type": {"type": "long", "logicalType": "timestamp-millis"}}
  ]
}
