{:name "Internal transfer between two accounts in the same org"
 :tags #{:transfers :internal :intra-org}

 ;; One customer org with two accounts both opened against the org's
 ;; auto-published settlement product (:prod-0) and auto-active
 ;; organization party (:party-0). Funds flow into the first account,
 ;; then a portion is moved to the second.
 :given
 [{:command :open-account     :args []}                         ; org-0, prod-0, party-0, acct-0
  {:command :add-account      :args [:org-0 :party-0 :prod-0]}  ; acct-1
  {:command :inbound-transfer :args [:acct-0 1000]}]

 :when
 [{:command :internal-transfer :args [:acct-0 :acct-1 400]}]

 :then
 [{:command :assert-no-anomaly :args []}
  {:command :assert-balance    :args [:acct-0 600]}
  {:command :assert-balance    :args [:acct-1 400]}]}
