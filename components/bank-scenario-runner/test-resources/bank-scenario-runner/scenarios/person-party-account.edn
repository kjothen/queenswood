{:name "Open an account for a person party"
 :tags #{:parties :person :lifecycle}

 ;; Creates a customer org (settlement product + org-party
 ;; auto-created), then a person-party (pending), activates them
 ;; (via the IDV bypass), and opens an account against the org's
 ;; settlement product *for* the person — the canonical "Arthur
 ;; opens his current account" shape (modulo product-type, which
 ;; we leave at settlement here).
 :given
 [{:command :open-account        :args []}                   ; org-0, prod-0, party-0 (org), acct-0
  {:command :create-person-party :args [:org-0]}             ; party-1 (pending)
  {:command :activate-party      :args [:party-1]}           ; party-1 active
  {:command :add-account         :args [:org-0 :party-1 :prod-0]}  ; acct-1 owned by person
  {:command :inbound-transfer    :args [:acct-0 1000]}]      ; fund settlement-side

 :when
 [{:command :internal-transfer :args [:acct-0 :acct-1 600]}]

 :then
 [{:command :assert-no-anomaly :args []}
  {:command :assert-balance    :args [:acct-0 400]}
  {:command :assert-balance    :args [:acct-1 600]}]}
