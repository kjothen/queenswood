{:name "Full happy path: two parties, two products, transfers, payment, interest"
 :tags #{:capstone :happy-path}

 ;; Replays the manual UI smoke test end-to-end:
 ;;
 ;;   - Customer org with a settlement account auto-created
 ;;   - Two products: current (rate 0) and savings (rate 3650 bps)
 ;;   - Two person parties — Arthur and Ford — each with a current
 ;;     and a savings account
 ;;   - Settlement funded with £50,000
 ;;   - Each party rewarded £1,000 into their current account
 ;;   - Arthur moves £750 current → savings
 ;;   - Ford moves £350 current → savings
 ;;   - Ford pays £25 outbound (scheme path)
 ;;   - Daily interest accrues on the savings products and is
 ;;     capitalised
 ;;
 ;; All amounts in pence (1 minor unit). Interest from capitalisation
 ;; lands in `:balance-type-interest-paid` on the customer side and
 ;; debits `:balance-type-default` on the settlement side, so the
 ;; only `available-balance` change after accrue + capitalise is on
 ;; the settlement account.

 :given
 [;; --- Org setup --------------------------------------------------
  ;; org-0, prod-0 (settlement, published), party-0 (org-party,
  ;; active), acct-0 (settlement)
  {:command :open-account           :args []}
  {:command :assert-no-anomaly      :args []}

  ;; --- Products ---------------------------------------------------
  ;; prod-1 = current (rate 0), prod-2 = savings (rate 3650 bps)
  {:command :create-product         :args [:org-0]}
  {:command :create-savings-product :args [:org-0 3650]}
  {:command :publish-product        :args [:prod-1]}
  {:command :publish-product        :args [:prod-2]}
  {:command :assert-no-anomaly      :args []}

  ;; --- Parties ----------------------------------------------------
  ;; Arthur Dent → party-1, Ford Prefect → party-2 (both active)
  {:command :create-person-party    :args [:org-0]}
  {:command :activate-party         :args [:party-1]}
  {:command :create-person-party    :args [:org-0]}
  {:command :activate-party         :args [:party-2]}
  {:command :assert-no-anomaly      :args []}

  ;; --- Customer accounts ------------------------------------------
  ;; acct-1 = Arthur current  acct-2 = Arthur savings
  ;; acct-3 = Ford   current  acct-4 = Ford   savings
  {:command :add-account            :args [:org-0 :party-1 :prod-1]}
  {:command :add-account            :args [:org-0 :party-1 :prod-2]}
  {:command :add-account            :args [:org-0 :party-2 :prod-1]}
  {:command :add-account            :args [:org-0 :party-2 :prod-2]}
  {:command :assert-no-anomaly      :args []}

  ;; --- Money in ---------------------------------------------------
  ;; £50,000 into settlement
  {:command :inbound-transfer       :args [:acct-0 5000000]}

  ;; £1,000 reward to each party's current
  {:command :internal-transfer      :args [:acct-0 :acct-1 100000]}
  {:command :internal-transfer      :args [:acct-0 :acct-3 100000]}
  {:command :assert-no-anomaly      :args []}]

 :when
 [;; --- Customer activity ------------------------------------------
  ;; Arthur: £750 current → savings
  {:command :internal-transfer      :args [:acct-1 :acct-2 75000]}
  ;; Ford: £350 current → savings
  {:command :internal-transfer      :args [:acct-3 :acct-4 35000]}
  ;; Ford: £25 outbound payment ("beer and nuts")
  {:command :outbound-payment       :args [:acct-3 2500]}]

 :then
 [;; --- Pre-interest balances --------------------------------------
  ;;   settlement   (acct-0): 50,000 - 1,000 - 1,000     = 48,000.00 = 4_800_000
  ;;   Arthur cur   (acct-1): 1,000 - 750                =    250.00 =    25_000
  ;;   Arthur sav   (acct-2):              + 750         =    750.00 =    75_000
  ;;   Ford   cur   (acct-3): 1,000 - 350 - 25           =    625.00 =    62_500
  ;;   Ford   sav   (acct-4):              + 350         =    350.00 =    35_000
  {:command :assert-no-anomaly      :args []}
  {:command :assert-balance         :args [:acct-0 4800000]}
  {:command :assert-balance         :args [:acct-1 25000]}
  {:command :assert-balance         :args [:acct-2 75000]}
  {:command :assert-balance         :args [:acct-3 62500]}
  {:command :assert-balance         :args [:acct-4 35000]}

  ;; --- Interest run -----------------------------------------------
  ;; Daily interest on savings at 3650 bps:
  ;;   Arthur sav  75_000 → 75 pence accrued
  ;;   Ford   sav  35_000 → 35 pence accrued
  ;; Both lands in customer.interest-accrued (not visible in
  ;; available); settlement.interest-payable goes -110.
  {:command :accrue-interest        :args [:org-0 20260501]}
  ;; Settlement available = default + interest-payable
  ;;   = 4_800_000 + (-110) = 4_799_890
  {:command :assert-balance         :args [:acct-0 4799890]}

  ;; Capitalisation has six legs per customer account; the last
  ;; pair credits the customer's default balance with the accrued
  ;; amount (the prior pairs unwind the intermediate
  ;; interest-paid / interest-accrued / interest-payable
  ;; positions). Net effect:
  ;;   settlement.default      -= 75 + 35 → 4_799_890
  ;;   Arthur savings.default  += 75      →    75_075
  ;;   Ford   savings.default  += 35      →    35_035
  ;; current accounts unchanged.
  {:command :capitalize-interest    :args [:org-0 20260501]}
  {:command :assert-balance         :args [:acct-0 4799890]}
  {:command :assert-balance         :args [:acct-1 25000]}
  {:command :assert-balance         :args [:acct-2 75075]}
  {:command :assert-balance         :args [:acct-3 62500]}
  {:command :assert-balance         :args [:acct-4 35035]}

  {:command :assert-no-anomaly      :args []}]}
