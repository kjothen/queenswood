{:name "Duplicate national-identifier within an org is rejected"
 :tags #{:rejection :parties}

 ;; Pins the rejection kind that the property test only sees as a
 ;; generic `:denied` outcome. Two creates with the same NI marker
 ;; in the same org — the second must reject with
 ;; `:party/duplicate-national-identifier` (the contractual kind
 ;; that API responses surface). Cross-org reuse is allowed and is
 ;; covered by the property test, so it isn't repeated here.

 :given
 [{:command :open-account       :args []}
  {:command :create-person-party :args [:org-0 :ni-shared]}
  {:command :assert-no-anomaly  :args []}]

 :when
 [{:command :create-person-party :args [:org-0 :ni-shared]}]

 :then
 [{:command :assert-outcome :args [:denied]}
  {:command :assert-rejection-kind
   :args [:party/duplicate-national-identifier]}]}
