{:name "Outbound payment via the scheme adapter path"
 :tags #{:payments :outbound}

 ;; Routes through `bank-payment/submit-outbound` rather than
 ;; record-transaction directly: same balance change as
 ;; `:outbound-transfer` (debit customer, credit settlement-suspense)
 ;; *and* persists an OutboundPayment record + publishes a scheme
 ;; command for the adapter. Balance assertion holds regardless of
 ;; the async scheme outcome — the legs are applied synchronously
 ;; inside submit-outbound.
 :given
 [{:command :open-account     :args []}                ; org-0, prod-0, party-0, acct-0
  {:command :inbound-transfer :args [:acct-0 1000]}]   ; fund customer

 :when
 [{:command :outbound-payment :args [:acct-0 250]}]    ; pay 25.00

 :then
 [{:command :assert-no-anomaly :args []}
  {:command :assert-balance    :args [:acct-0 750]}]}
