{
  "type": "record",
  "name": "PersonIdentification",
  "namespace": "com.repldriven.mono.person_identification",
  "fields": [
    {"name": "party_id",      "type": "string"},
    {"name": "given_name",    "type": "string"},
    {"name": "middle_names",  "type": ["null", "string"], "default": null},
    {"name": "family_name",   "type": "string"},
    {"name": "date_of_birth", "type": "int", "doc": "YYYYMMDD"},
    {"name": "nationality",   "type": "string", "doc": "ISO 3166-1 alpha-2"},
    {"name": "created_at", "type": {"type": "long", "logicalType": "timestamp-millis"}},
    {"name": "updated_at", "type": {"type": "long", "logicalType": "timestamp-millis"}}
  ]
}
