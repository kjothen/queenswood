{
  "type": "record",
  "name": "Account",
  "namespace": "com.repldriven.mono.accounts.account_lifecycle",
  "fields": [
    {"name": "account_id",  "type": "string"},
    {"name": "customer_id", "type": "string"},
    {"name": "name",        "type": "string"},
    {"name": "currency",    "type": "string"},
    {"name": "status",      "type": "string"},
    {"name": "created_at_ms", "type": {"type": "long", "logicalType": "timestamp-millis"}},
    {"name": "updated_at_ms", "type": {"type": "long", "logicalType": "timestamp-millis"}},
    {"name": "payment_addresses",
     "type": {"type": "array",
              "items": {
                "type": "record",
                "name": "PaymentAddress",
                "fields": [
                  {"name": "scheme", "type": "string"},
                  {"name": "scan",
                   "type": ["null",
                            {"type": "record",
                             "name": "ScanAddress",
                             "fields": [
                               {"name": "sort_code", "type": "string"},
                               {"name": "account_number", "type": "string"}
                             ]}],
                   "default": null},
                  {"name": "value",
                   "type": ["null", "string"],
                   "default": null}
                ]}},
     "default": []}
  ]
}
