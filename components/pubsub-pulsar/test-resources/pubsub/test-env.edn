{:system
 {:pubsub
  {:container
   {:docker-image-name "apachepulsar/pulsar:2.11.0-SNAPSHOT"
    :exposed-ports [6650 8080]}
   :container-service-port
   {:container [#system :local-ref [:container]]
    :exposed-port 6650}
   :container-service-url
   {:scheme "pulsar"
    :port [#system :ref
           [:pubsub
            :container-service-port]]}
   :container-service-http-port
   {:container [#system :local-ref [:container]]
    :exposed-port 8080}
   :container-service-http-url
   {:scheme "http"
    :port [#system :ref
           [:pubsub
            :container-service-http-port]]}
   :admin {:service-http-url
           [#system :local-ref [:container-service-http-url]]}
   :client {:service-url [#system :local-ref [:container-service-url]]}
   :schemas {:user {:type "AVRO" :schema "schema-avro/user.avsc.json"}
             :computer {:type "STRING"}}
   :tenants {:admin [#system :local-ref [:admin]]
             :tenants #include "test-tenants.edn"}
   :namespaces {:_ [#system :local-ref [:tenants]]
                :admin [#system :local-ref [:admin]]
                :namespaces #include "test-namespaces.edn"}
   :topics
   {:_ [#system :local-ref [:namespaces]]
    :admin [#system :local-ref [:admin]]
    :schemas [#system :local-ref [:schemas]]
    :topics #include "test-topics.edn"}
   :crypto-key-pair-generator
   {"tenant-key-1"
    {:algorithm "RSA" :key-size 512}}
   :crypto-key-pair-file-readers
   {:1 {"tenant-key-1"
        {:public-key "pubsub/test_ecdsa_pubkey.pem"
         :private-key "pubsub/test_ecdsa_privkey.pem"}}
    :2 {"tenant-key-2"
        {:public-key "pubsub/test-2_ecdsa_pubkey.pem"
         :private-key "pubsub/test-2_ecdsa_privkey.pem"}}}
   :crypto-key-readers
   {:1 {:default-key "tenant-key-1"
        :keys [#system :local-ref [:crypto-key-pair-file-readers :1]]}
    :2 {:default-key "tenant-key-2"
        :keys [#system :ref [:pubsub :crypto-key-pair-file-readers :2]]}}
   :consumers
   {:1 {:_ [#system :local-ref [:topics]]
        :client [#system :local-ref [:client]]
        :conf {"cryptoFailureAction" #pubsub-crypto-failure-action :CONSUME
               "cryptoKeyReader" [#system :local-ref [:crypto-key-readers :1]]
               "schema" #pubsub-schema :AUTO_CONSUME
               "subscriptionName" "tenant-1-subscriber"
               "subscriptionType" #pubsub-subscription-type :Shared
               "topicNames" #{"persistent://tenant-1/namespace-1/topic-1"}}
        :schemas [#system :local-ref [:schemas]]}
    :2 {:_ [#system :local-ref [:topics]]
        :client [#system :local-ref [:client]]
        :conf {"cryptoFailureAction" #pubsub-crypto-failure-action :CONSUME
               "cryptoKeyReader" [#system :local-ref [:crypto-key-readers :2]]
               "schema" #pubsub-schema :AUTO_CONSUME
               "subscriptionName" "tenant-2-subscriber"
               "subscriptionType" #pubsub-subscription-type :Shared
               "topicNames" #{"persistent://tenant-1/namespace-1/topic-1"}}
        :schemas [#system :local-ref [:schemas]]}}
   ;;:reader
   ;;{:_topics [#system :local-ref [:topics]]
   ;; :client [#system :local-
   ;; :conf {"cryptoKeyReader" [#system :local-ref [:crypto-key-reader]]
   ;;        "schema" #pubsub-schema :AUTO_CONSUME
   ;;        "startMessageId" #pubsub-message-id :earliest
   ;;        "topicNames" #{"persistent://tenant-1/namespace-1/topic-1"}}
   ;;           :schemas  [#system :local-ref [:schemas]]}
   :producer
   {:_ [#system :local-ref [:topics]]
    :client [#system :local-ref [:client]]
    :conf {"cryptoKeyReader" [#system :local-ref [:crypto-key-readers :1]]
           "encryptionKeys" #{"tenant-key-1"}
           "schema" #pubsub-schema :AUTO_PRODUCE_BYTES
           "topicName" "persistent://tenant-1/namespace-1/topic-1"}
    :schemas [#system :local-ref [:schemas]]}
    }}}
