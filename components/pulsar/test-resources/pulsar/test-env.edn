{:system
 {:pulsar
  {:container {:docker-image-name "kezhenxu94/pulsar:latest"
               :exposed-ports [6650 8080]}
   :container-service-port {:container [#system :ref [:pulsar :container]]
                            :exposed-port 6650}
   :container-service-url {:scheme "pulsar"
                           :port [#system :ref
                                  [:pulsar
                                   :container-service-port]]}
   :container-service-http-port {:container [#system :ref [:pulsar :container]]
                                 :exposed-port 8080}
   :container-service-http-url {:scheme "http"
                                :port [#system :ref
                                       [:pulsar
                                        :container-service-http-port]]}
   :admin {:service-http-url [#system :ref [:pulsar :container-service-http-url]]}
   :client {:service-url [#system :ref [:pulsar :container-service-url]]}
   :topics {:admin [#system :ref [:pulsar :admin]]
            :topics-and-opts [{:topic "persistent://tenant-1/namespace-1/topic-1"}]}
   :crypto-key-pair-generator {"tenant-key-1" {:algorithm "RSA" :key-size 512}}
   :crypto-key-reader {:default-key "tenant-key-1"
                       :keys [#system :ref [:pulsar :crypto-key-pair-generator]]}
   :consumer {:_topics [#system :ref [:pulsar :topics]]
              :client [#system :ref [:pulsar :client]]
              :conf {"startMessageId" #pulsar-message-id :earliest
                     "subscriptionName" "tenant-1-subscriber"
                     "cryptoKeyReader" [#system :ref [:pulsar :crypto-key-reader]]
                     "topicNames" ["persistent://tenant-1/namespace-1/topic-1"]}}
   :producer {:_topics [#system :ref [:pulsar :topics]]
              :client [#system :ref [:pulsar :client]]
              :conf {"topic" "persistent://tenant-1/namespace-1/topic-1"
                     "encryptionKey" "tenant-key-1"
                     "cryptoKeyReader" [#system :ref [:pulsar :crypto-key-reader]]}}
   }}}
