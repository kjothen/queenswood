{:system
 {:pulsar
  {:container {;;:docker-image-name "kezhenxu94/pulsar:latest"
               :exposed-ports [6650 8080]}
   :container-service-port {:container [#system :ref [:pulsar :container]]
                            :exposed-port 6650}
   :container-service-url {:scheme "pulsar"
                           :port [#system :ref
                                  [:pulsar
                                   :container-service-port]]}
   :container-service-http-port {:container [#system :ref [:pulsar :container]]
                                 :exposed-port 8080}
   :container-service-http-url {:scheme "http"
                                :port [#system :ref
                                       [:pulsar
                                        :container-service-http-port]]}
   :admin {:service-http-url [#system :ref [:pulsar :container-service-http-url]]}
   :client {:service-url [#system :ref [:pulsar :container-service-url]]}
   :schemas {:user
             {:type "AVRO"
              :schema {:type "record"
                       :name "User"
                       :namespace "com.repldriven.mono"
                       :fields [{:name "name"
                                 :type "string"}
                                {:name "age"
                                 :type ["null", "long"]
                                 :default nil}]}
              :properties {}}}
   :topics {:admin [#system :ref [:pulsar :admin]]
            :tenants [{:tenant "tenant-1"
                       :roles []
                       :clusters ["standalone"]}]
            :namespaces [{:namespace "tenant-1/namespace-1"
                          :config {:post {"autoTopicCreation"
                                          {"topicType" "string"
                                           "defaultNumPartitions" 1
                                           "allowAutoTopicCreation" false}
                                          "encryptionRequired" true
                                          "isAllowAutoUpdateSchema" false
                                          "schemaValidationEnforced" true
                                          }
                                   :put {"schemaCompatibilityStrategy"
                                         "FULL"}
                                   }}]
            :schemas [#system :ref [:pulsar :schemas]]
            :topics [{:topic "persistent://tenant-1/namespace-1/topic-1"
                      :partitions 1
                      :schema :user}]}
   :crypto-key-pair-generator {"tenant-key-1"
                               {:algorithm "RSA" :key-size 512}}
   :crypto-key-pair-file-reader {"tenant-key-1"
                                 {:public-key "pulsar/test_ecdsa_pubkey.pem"
                                  :private-key "pulsar/test_ecdsa_privkey.pem"}}
   :crypto-key-reader {:default-key "tenant-key-1"
                       :keys [#system :ref [:pulsar :crypto-key-pair-file-reader]]}
   :consumer {:_topics [#system :ref [:pulsar :topics]]
              :client [#system :ref [:pulsar :client]]
              :conf {"cryptoKeyReader" [#system :ref [:pulsar :crypto-key-reader]]
                     "schema" {:type "AUTO_CONSUME"}
                     "subscriptionName" "tenant-1-subscriber"
                     "topics" ["persistent://tenant-1/namespace-1/topic-1"]}
              :schemas  [#system :ref [:pulsar :schemas]]}
   :producer {:_topics [#system :ref [:pulsar :topics]]
              :client [#system :ref [:pulsar :client]]
              :conf {"cryptoKeyReader" [#system :ref [:pulsar :crypto-key-reader]]
                     "encryptionKeys" ["tenant-key-1"]
                     "schema" {:type "AUTO_PRODUCE_BYTES"}
                     "topic" "persistent://tenant-1/namespace-1/topic-1"}
              :schemas  [#system :ref [:pulsar :schemas]]}
   }}}
